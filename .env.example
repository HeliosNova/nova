# Nova Configuration
# Copy to .env and customize. All values shown are defaults.

# --- LLM Provider ---
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:27b
# After fine-tuning, update to your versioned tag, e.g.: LLM_MODEL=nova-ft-v8-q8
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3
# bge-m3 won a 2026 paraphrase-retrieval bake-off (see app/core/embedding.py).
# Set to "default" to use ChromaDB's bundled all-MiniLM-L6-v2 (zero GPU/network,
# lower recall) on modest hardware that hasn't pulled an Ollama embedder.

# Cloud provider API keys (required when LLM_PROVIDER != ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Provider base URLs (for self-hosted / proxy setups)
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
ANTHROPIC_API_VERSION=2024-10-22

# --- MCP (Model Context Protocol) ---
ENABLE_MCP=true
MCP_CONFIG_DIR=/data/mcp
ENABLE_MCP_SERVER=true
MCP_SERVER_NAME=nova

# --- Search ---
SEARXNG_URL=http://searxng:8080

# --- Security ---
SYSTEM_ACCESS_LEVEL=sandboxed
# Auth: the compose file binds all ports to 127.0.0.1 (localhost only), so out of
# the box Nova runs key-less for the single local user. BEFORE exposing Nova to a
# network (changing the 127.0.0.1 bindings or putting it behind a reverse proxy),
# set NOVA_API_KEY to a long random string AND REQUIRE_AUTH=true — otherwise your
# instance is publicly accessible. With REQUIRE_AUTH=true and an empty key, every
# request returns 503 "API key not configured" (a deliberate fail-closed guard).
NOVA_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173
ENABLE_INJECTION_DETECTION=true
REQUIRE_SIGNED_SKILLS=true
REQUIRE_AUTH=false
TRUSTED_PROXY=
AUTH_MAX_FAILURES=10
AUTH_LOCKOUT_SECONDS=300
AUTH_MAX_TRACKED_IPS=10000

# --- Tool Timeouts ---
TOOL_TIMEOUT=120
GENERATION_TIMEOUT=480
INTERNAL_LLM_TIMEOUT=30
CODE_EXEC_TIMEOUT=10
SHELL_EXEC_TIMEOUT=30
BROWSER_TIMEOUT=30
BROWSER_CDP_URL=
MAX_TOOL_ROUNDS=5
TOOL_OUTPUT_MAX_CHARS=4000
ENABLE_SHELL_EXEC=false

# --- Context & Memory ---
MAX_CONTEXT_TOKENS=16000
RECENT_MESSAGES_KEEP=12
MAX_SYSTEM_TOKENS=6000
MAX_HISTORY_MESSAGES=20
MAX_LESSONS_IN_PROMPT=5
MAX_SKILLS_CHECK=10

# --- Retrieval ---
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RRF_K=60

# --- Limits ---
MAX_USER_FACTS=30
MAX_KG_FACTS=1000
MAX_KG_FACTS_IN_PROMPT=8
MAX_REFLEXIONS=200
MAX_REFLEXIONS_IN_PROMPT=3
MAX_SUCCESS_PATTERNS_IN_PROMPT=2
MAX_LESSONS=500
MAX_CURIOSITY_PENDING=50
MAX_CURIOSITY_ATTEMPTS=3
MAX_CUSTOM_TOOL_CODE_LENGTH=5000
MAX_CUSTOM_TOOLS=50
RATE_LIMIT_RPM=60
MAX_QUERY_LENGTH=50000

# --- Critique ---
MAX_CRITIQUE_ROUNDS=3
CRITIQUE_ANSWER_LIMIT=1500
CRITIQUE_SOURCES_LIMIT=1500
CRITIQUE_FACTS_LIMIT=2000

# --- Reasoning ---
ENABLE_PLANNING=true
ENABLE_CRITIQUE=true
ENABLE_CUSTOM_TOOLS=true
ENABLE_EXTENDED_THINKING=true

# --- MAD-MM Memory Masking ---
# Opt-in subjective memory masking for the agent_loop iteration
# (arxiv 2603.20215, ICLR 2026). When a step is being retried, ask the LLM
# which prior step observations and findings are actually useful for the
# current step — drops the rest before rendering the scratchpad. Adds one
# batched LLM call per retry; off by default.
ENABLE_MAD_MM_MASKING=false
MAD_MM_MIN_PRIOR_STEPS=3

# --- Two-Phase Dream Consolidation ---
# SCM/SleepGate-style split (arxiv 2604.20943 + 2603.14517). Dream Phase 3
# splits into NREM (structural / deterministic substeps: prune, compact,
# disable; ~5s) and REM (integrative / LLM substeps: promote, resolve,
# generalize; ~60s). REM failures no longer roll back NREM. Off by default
# while we measure the actual time split in your environment.
ENABLE_TWO_PHASE_DREAM=false
DREAM_REM_TIMEOUT_SECONDS=60

# --- Model Routing ---
VISION_MODEL=qwen3.5:9b
FAST_MODEL=qwen3.5:4b
HEAVY_MODEL=
ENABLE_MODEL_ROUTING=true

# --- Delegation ---
ENABLE_DELEGATION=true
MAX_DELEGATION_DEPTH=1

# --- Background Tasks ---
MAX_BACKGROUND_TASKS=5
BACKGROUND_TASK_TIMEOUT=300

# --- Tuning Parameters ---
RESPONSE_TOKEN_BUDGET=600
RETRIEVAL_RELEVANCE_THRESHOLD=0.15
TEMPERATURE_DEFAULT=0.7
TEMPERATURE_INTERNAL=0.3
TEMPERATURE_REFLEXION=0.4
MIN_RRF_SCORE=0.015
DEDUP_JACCARD_THRESHOLD=0.85
REFLEXION_DECAY_DAYS=90
REFLEXION_DECAY_AMOUNT=0.05
REFLEXION_DISTANCE_THRESHOLD=0.7
SKILL_EMA_ALPHA=0.15
INJECTION_SUSPICIOUS_THRESHOLD=0.3
FACT_INJECTION_SKIP_THRESHOLD=0.3
FACT_CONFIDENCE_EXTRACTED=0.65
FACT_CONFIDENCE_USER=0.9
REFLEXION_FAILURE_THRESHOLD=0.6
REFLEXION_SUCCESS_THRESHOLD=0.8
KG_GRAPH_MAX_FRONTIER=1000

# --- Learning ---
TRAINING_DATA_PATH=/data/training_data.jsonl
TRAINING_DATA_CHANNELS=api
MAX_TRAINING_PAIRS=10000

# --- Skills ---
ENABLE_AUTO_SKILL_CREATION=true
SKILLS_DIR=/data/skills

# --- Curiosity ---
ENABLE_CURIOSITY=true

# --- Heartbeat / Proactive ---
ENABLE_HEARTBEAT=true
HEARTBEAT_INTERVAL=60
ENABLE_PROACTIVE=true
DIGEST_HOUR=21

# --- Desktop Automation ---
ENABLE_DESKTOP_AUTOMATION=false
DESKTOP_CLICK_DELAY=0.5
SCREENSHOT_DIR=/tmp/nova_screenshots

# --- Voice ---
ENABLE_VOICE=false
WHISPER_MODEL_SIZE=base
VOICE_MAX_DURATION=300

# --- Email ---
ENABLE_EMAIL_SEND=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_SMTP_TLS=true
EMAIL_ALLOWED_RECIPIENTS=

# --- Calendar ---
ENABLE_CALENDAR=true
CALENDAR_PATH=/data/calendar.ics

# --- Webhooks ---
ENABLE_WEBHOOKS=false
WEBHOOK_ALLOWED_URLS=

# --- Integrations ---
ENABLE_INTEGRATIONS=true

# --- Channels (leave empty to disable) ---
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ALLOWED_USERS=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USERS=

# WhatsApp (Business API)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_CHAT_ID=
WHATSAPP_ALLOWED_USERS=
WHATSAPP_APP_SECRET=

# Signal (signal-cli REST API)
SIGNAL_API_URL=
SIGNAL_PHONE_NUMBER=
SIGNAL_CHAT_ID=
SIGNAL_ALLOWED_USERS=
SIGNAL_POLL_INTERVAL=2

# --- Fine-tuning ---
# Threshold for the Fine-Tune Check monitor to notify "ready". Set 2026-05-14
# (task #23) to 100 — matches the monthly-cadence policy at ~3.3 pairs/day
# organic accumulation. Lower values triggered notifies before the new-data
# delta was big enough to A/B-differentiate (the #41 smoke on 19 pairs A/B'd
# 10/10 ties).
FINETUNE_MIN_NEW_PAIRS=100
FINETUNE_OUTPUT_DIR=/data/finetune

# --- Database ---
DB_PATH=/data/nova.db
CHROMADB_PATH=/data/chromadb

# --- Server ---
PORT=8000
